# .env.e2e — copy to .env.e2e and fill in values from Phase 0.
# DO NOT commit .env.e2e. The .example file is the only one tracked.

ZITADEL_TEST_USER=
ZITADEL_TEST_PASSWORD=
ZITADEL_AUTH_URL=https://auth2.defernowork.com
MCP_SERVER_UNDER_TEST=https://app2.defernowork.com/mcp

# Anthropic API key — required for Claude Code itself to call the model.
# Without this, `claude -p` silently exits with "Invalid API key · Please run /login".
ANTHROPIC_ENVIRONMENT=
ANTHROPIC_API_KEY_NAME=
ANTHROPIC_API_KEY=