  "auth": "bearer",
  "request": {
    "headers_required": ["Authorization"],
    "body": {
      "required": [],
      "optional": ["name", "query_string"],
      "example": {"name": "Renamed search"}
    }
  },
  "responses": [
    {
      "status": 200,
      "shape": {
        "id": "uuid",
        "name": "string",
        "query_string": "string",
